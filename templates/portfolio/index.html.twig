{% extends 'base.html.twig' %}
{% import '_macros/info_tooltip.html.twig' as ui %}

{% block title %}{{ 'portfolio.page_title'|trans }}{% endblock %}

{% block body %}
    <div class="space-y-8" data-controller="form-modal" data-action="submit->form-modal#submit">
        {# Page header #}
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-gray-900">{{ 'portfolio.title'|trans }}</h1>
                {% if portfolioValueEur is not null %}
                    <p class="mt-2 text-3xl font-semibold tabular-nums text-gray-900">€{{ portfolioValueEur }}</p>
                {% endif %}
                <p class="mt-1 text-sm text-gray-500">
                    {{ 'portfolio.holdings_count'|trans({'%count%': holdings|length}) }}
                    · {{ 'portfolio.transactions_count'|trans({'%count%': transactions|length}) }}
                    {% if transactions|length > 0 %}
                        · {{ 'portfolio.last_activity'|trans({'%date%': transactions[0].occurredAt|date('M j, Y')}) }}
                    {% endif %}
                </p>
            </div>
            <div class="flex items-center gap-2">
                <a href="{{ path('portfolio_import') }}" data-action="form-modal#open" class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">{{ 'portfolio.cta_import'|trans }}</a>
                <a href="{{ path('portfolio_transaction_new') }}" data-action="form-modal#open" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500">{{ 'portfolio.cta_record'|trans }}</a>
            </div>
        </div>

        {# Realized gains hero stats #}
        {% if realizedGains is not null and realizedGains.perAsset|length > 0 %}
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="rounded-xl border border-gray-200 bg-white px-6 py-5 shadow-sm">
                    <p class="flex items-center text-xs font-medium uppercase tracking-wide text-gray-500">
                        <span>{{ 'portfolio.realized_gains_hero_gain'|trans({'%year%': realizedGainsYear}) }}</span>
                        {{ ui.info_tooltip('portfolio.realized_gains_hero_gain_tooltip'|trans) }}
                    </p>
                    <p class="mt-2 text-3xl font-semibold tabular-nums {{ realizedGains.totalGainEur.isNegative ? 'text-rose-600' : 'text-emerald-600' }}">
                        €{{ realizedGains.totalGainEur.amount|number_format(2, '.', '') }}
                    </p>
                </div>
                <div class="rounded-xl border border-gray-200 bg-white px-6 py-5 shadow-sm">
                    <p class="flex items-center text-xs font-medium uppercase tracking-wide text-gray-500">
                        <span>{{ 'portfolio.realized_gains_hero_cost'|trans({'%year%': realizedGainsYear}) }}</span>
                        {{ ui.info_tooltip('portfolio.realized_gains_hero_cost_tooltip'|trans) }}
                    </p>
                    <p class="mt-2 text-3xl font-semibold tabular-nums text-gray-900">
                        €{{ realizedGains.totalCostBasisEur.amount|number_format(2, '.', '') }}
                    </p>
                </div>
            </div>
        {% endif %}

        {# Holdings #}
        <section>
            <h2 class="text-xs font-semibold uppercase tracking-wide text-gray-500">{{ 'portfolio.holdings_title'|trans }}</h2>
            {% if holdings is empty %}
                <div class="mt-3 rounded-xl border border-dashed border-gray-300 bg-white px-6 py-12 text-center">
                    <p class="text-sm text-gray-500">{{ 'portfolio.holdings_empty'|trans }}</p>
                </div>
            {% else %}
                <div class="mt-3 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50/80 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                            <tr>
                                <th class="px-6 py-3">{{ 'portfolio.holdings_th_asset'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.holdings_th_quantity'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.holdings_th_avg_cost'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.holdings_th_price'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.holdings_th_value'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            {% for holding in holdings %}
                                <tr class="transition hover:bg-gray-50">
                                    <td class="px-6 py-3 font-medium text-gray-900">{{ holding.asset }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums text-gray-700">{{ holding.quantity }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums text-gray-700">{{ holding.averageCost }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums text-gray-500">{{ holding.pricePerUnitEur ?? '—' }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums font-medium text-gray-900">{{ holding.valueEur is not null ? '€' ~ holding.valueEur : '—' }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if portfolioValueEur is not null %}
                    <p class="mt-2 text-xs text-gray-400">{{ 'portfolio.holdings_price_note'|trans }}</p>
                {% endif %}
            {% endif %}
        </section>

        {# Realized gains by asset #}
        {% if realizedGains is not null and realizedGains.perAsset|length > 0 %}
            <section>
                <h2 class="text-xs font-semibold uppercase tracking-wide text-gray-500">{{ 'portfolio.realized_gains_title'|trans({'%year%': realizedGainsYear}) }}</h2>
                <div class="mt-3 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50/80 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                            <tr>
                                <th class="px-6 py-3">{{ 'portfolio.realized_gains_th_asset'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.realized_gains_th_proceeds'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.realized_gains_th_cost'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.realized_gains_th_gain'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            {% for line in realizedGains.perAsset %}
                                <tr class="transition hover:bg-gray-50">
                                    <td class="px-6 py-3 font-medium text-gray-900">{{ line.asset }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums text-gray-700">€{{ line.proceedsEur.amount|number_format(2, '.', '') }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums text-gray-700">€{{ line.costBasisEur.amount|number_format(2, '.', '') }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums font-medium {{ line.gainEur.isNegative ? 'text-rose-600' : 'text-emerald-600' }}">€{{ line.gainEur.amount|number_format(2, '.', '') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <p class="mt-2 text-xs text-gray-400">{{ 'portfolio.realized_gains_method_note'|trans }}</p>
                {% if realizedGains.unmatchedSellCount > 0 %}
                    <p class="mt-1 text-xs text-amber-600">{{ 'portfolio.realized_gains_unmatched_note'|trans({'%count%': realizedGains.unmatchedSellCount}) }}</p>
                {% endif %}
            </section>
        {% endif %}

        {# Transactions #}
        <section>
            <h2 class="text-xs font-semibold uppercase tracking-wide text-gray-500">{{ 'portfolio.transactions_title'|trans }}</h2>
            {% if transactions is empty %}
                <div class="mt-3 rounded-xl border border-dashed border-gray-300 bg-white px-6 py-12 text-center">
                    <p class="text-sm text-gray-500">{{ 'portfolio.transactions_empty'|trans }}</p>
                </div>
            {% else %}
                <div class="mt-3 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50/80 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                            <tr>
                                <th class="px-6 py-3">{{ 'portfolio.transactions_th_date'|trans }}</th>
                                <th class="px-6 py-3">{{ 'portfolio.transactions_th_asset'|trans }}</th>
                                <th class="px-6 py-3">{{ 'portfolio.transactions_th_side'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.transactions_th_quantity'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.transactions_th_price'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.transactions_th_fee'|trans }}</th>
                                <th class="px-6 py-3">{{ 'portfolio.transactions_th_source'|trans }}</th>
                                <th class="px-6 py-3"><span class="sr-only">{{ 'portfolio.transactions_actions'|trans }}</span></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            {% for transaction in transactions %}
                                <tr class="transition hover:bg-gray-50">
                                    <td class="whitespace-nowrap px-6 py-3 text-gray-500">{{ transaction.occurredAt|date('Y-m-d H:i') }}</td>
                                    <td class="px-6 py-3 font-medium text-gray-900">{{ transaction.asset }}</td>
                                    <td class="px-6 py-3">
                                        <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset {{ transaction.side.value == 'buy' ? 'bg-emerald-50 text-emerald-700 ring-emerald-200' : 'bg-rose-50 text-rose-700 ring-rose-200' }}">
                                            {{ ('transaction.side.' ~ transaction.side.value)|trans }}
                                        </span>
                                    </td>
                                    <td class="px-6 py-3 text-right tabular-nums text-gray-700">{{ transaction.quantity }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums text-gray-700">{{ transaction.price }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums text-gray-500">{{ transaction.fee }}</td>
                                    <td class="px-6 py-3">
                                        <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium {{ transaction.source == 'manual' ? 'bg-gray-100 text-gray-600' : 'bg-indigo-50 text-indigo-700 ring-1 ring-inset ring-indigo-200' }}">
                                            {{ ('transaction.source.' ~ transaction.source)|trans }}
                                        </span>
                                    </td>
                                    <td class="px-6 py-3 text-right">
                                        <a href="{{ path('portfolio_transaction_edit', {'id': transaction.id.value}) }}" data-action="form-modal#open" class="font-medium text-indigo-600 hover:text-indigo-500">{{ 'portfolio.transactions_edit'|trans }}</a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </section>

        {# Shared modal for Record / Import / Edit #}
        <dialog data-form-modal-target="dialog" class="fixed inset-0 m-auto h-fit max-h-[calc(100vh-2rem)] w-full max-w-2xl overflow-y-auto rounded-2xl border border-gray-200 bg-white p-0 shadow-xl backdrop:bg-gray-900/40 backdrop:backdrop-blur-sm">
            <div class="flex items-center justify-end border-b border-gray-100 px-4 py-3">
                <button type="button" data-action="form-modal#close" aria-label="{{ 'portfolio.modal_close'|trans }}" class="rounded text-gray-400 hover:text-gray-600">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div data-form-modal-target="body" class="px-6 py-6"></div>
        </dialog>
    </div>
{% endblock %}
