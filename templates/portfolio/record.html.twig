{% extends 'base.html.twig' %}

{% block title %}{{ 'portfolio.record_page_title'|trans }}{% endblock %}

{% block body %}
    <div class="max-w-lg space-y-4">
        <a href="{{ path('portfolio') }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">{{ 'portfolio.back_link'|trans }}</a>

        <div data-modal-content class="space-y-4">
            <h1 class="text-xl font-semibold text-gray-900">{{ 'portfolio.record_title'|trans }}</h1>

            <div class="rounded-lg border border-gray-200 bg-white p-6">
                {# Explicit action: form is injected into a modal on /portfolio,
                   so an empty action would post to /portfolio (the listing route). #}
                {{ form_start(transactionForm, {action: path('portfolio_transaction_new'), 'attr': {'data-turbo': 'false'}}) }}
                    {{ form_row(transactionForm.asset) }}
                    {{ form_row(transactionForm.side) }}
                    {{ form_row(transactionForm.quantity) }}
                    {{ form_row(transactionForm.price) }}
                    {{ form_row(transactionForm.fee) }}
                    {{ form_row(transactionForm.occurredAt) }}
                    <button type="submit" class="mt-2 w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">{{ 'portfolio.record_submit'|trans }}</button>
                {{ form_end(transactionForm) }}
            </div>
        </div>
    </div>
{% endblock %}
