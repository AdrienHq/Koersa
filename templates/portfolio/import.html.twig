{% extends 'base.html.twig' %}

{% block title %}Import transactions · Koersa{% endblock %}

{% block body %}
    <div class="max-w-lg space-y-6">
        <div class="flex items-center justify-between">
            <h1 class="text-2xl font-semibold text-gray-900">Import from an exchange</h1>
            <a href="{{ path('portfolio') }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">Back to portfolio</a>
        </div>

        <p class="text-sm text-gray-500">Upload a CSV export from your exchange. Buy and sell trades are imported; deposits, withdrawals and transfers are skipped for now.</p>

        <div class="rounded-lg border border-gray-200 bg-white p-6">
            {{ form_start(importForm, {'attr': {'data-turbo': 'false'}}) }}
                {{ form_row(importForm.exchange) }}
                {{ form_row(importForm.file) }}
                <button type="submit" class="mt-2 w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">Import</button>
            {{ form_end(importForm) }}
        </div>
    </div>
{% endblock %}
