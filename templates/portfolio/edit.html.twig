{% extends 'base.html.twig' %}

{% block title %}Edit transaction · Koersa{% endblock %}

{% block body %}
    <div class="max-w-lg space-y-6">
        <div class="flex items-center justify-between">
            <h1 class="text-2xl font-semibold text-gray-900">Edit transaction</h1>
            <a href="{{ path('portfolio') }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">Back to portfolio</a>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-6">
            {{ form_start(transactionForm, {'attr': {'data-turbo': 'false'}}) }}
                {{ form_row(transactionForm.asset) }}
                {{ form_row(transactionForm.side) }}
                {{ form_row(transactionForm.quantity) }}
                {{ form_row(transactionForm.price) }}
                {{ form_row(transactionForm.fee) }}
                {{ form_row(transactionForm.occurredAt) }}
                <button type="submit" class="mt-2 w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">Save changes</button>
            {{ form_end(transactionForm) }}
        </div>

        <div class="rounded-lg border border-red-200 bg-white p-6">
            <h2 class="text-sm font-medium text-gray-900">Remove transaction</h2>
            <p class="mt-1 text-sm text-gray-500">This deletes the transaction from your portfolio.</p>
            {{ form_start(deleteForm, {'attr': {'data-turbo': 'false'}}) }}
                <button type="submit" class="mt-3 rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-500">Delete</button>
            {{ form_end(deleteForm) }}
        </div>
    </div>
{% endblock %}
