<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}" class="h-full">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="theme-color" content="#4f46e5">
        <meta name="color-scheme" content="light">
        <title>{% block title %}Koersa{% endblock %}</title>
        {% block metadata %}{% endblock %}
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📈</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="flex min-h-full flex-col bg-gray-50 text-gray-900 antialiased" data-controller="paywall">
        {% if is_granted('ROLE_ADMIN') %}
            {# Sideways red ribbon on the right edge: identity cue (you are admin) and entry point into /admin in one element. #}
            <a href="{{ path('admin') }}" aria-label="{{ 'layout.nav_admin'|trans }}" class="fixed right-0 top-1/2 z-50 flex min-h-64 -translate-y-1/2 items-center justify-center rounded-l-2xl bg-red-600 pl-3 pr-2 text-xs font-semibold uppercase tracking-[0.25em] text-white shadow-lg transition hover:bg-red-700">
                <span style="writing-mode: vertical-rl;">{{ 'layout.nav_admin'|trans }}</span>
            </a>
        {% endif %}
        <header class="border-b border-gray-200 bg-white">
            <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
                <a href="{{ path('home') }}" class="text-lg font-semibold tracking-tight text-indigo-600">Koersa</a>
                <div class="flex items-center gap-4 text-sm">
                    {% if app.user %}
                        {% set _route = app.request.attributes.get('_route') %}
                        <a href="{{ path('overview') }}" class="font-medium {{ _route == 'overview' ? 'text-indigo-600' : 'text-gray-600 hover:text-gray-900' }}">{{ 'layout.nav_overview'|trans }}</a>
                        <a href="{{ path('portfolio') }}" class="font-medium {{ _route in ['portfolio', 'portfolio_transaction_new', 'portfolio_transaction_edit', 'portfolio_import'] ? 'text-indigo-600' : 'text-gray-600 hover:text-gray-900' }}">{{ 'layout.nav_portfolio'|trans }}</a>
                        <a href="{{ path('tax') }}" class="font-medium {{ _route == 'tax' ? 'text-indigo-600' : 'text-gray-600 hover:text-gray-900' }}">{{ 'layout.nav_tax'|trans }}</a>
                        <span class="hidden text-gray-500 sm:inline">{{ app.user.userIdentifier }}</span>
                        <a href="{{ path('logout') }}" class="font-medium text-gray-600 hover:text-gray-900">{{ 'layout.nav_log_out'|trans }}</a>
                    {% else %}
                        <a href="{{ path('login') }}" class="font-medium text-gray-600 hover:text-gray-900">{{ 'layout.nav_sign_in'|trans }}</a>
                        <a href="{{ path('register') }}" class="rounded-md bg-indigo-600 px-3 py-1.5 font-medium text-white hover:bg-indigo-500">{{ 'layout.nav_register'|trans }}</a>
                    {% endif %}
                </div>
            </nav>
        </header>

        {% block main %}
            <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-8">
                {% block flashes %}{% endblock %}

                {% block body %}{% endblock %}
            </main>
        {% endblock %}

        {% if app.user and not is_paid_user(app.user) %}
            {% include '_paywall/dialog.html.twig' %}
        {% endif %}

        {# Toast stack — fixed bottom-right, each toast auto-dismisses.
           app.flashes drains the bag on each call, so capture once. #}
        {% set flashes = app.flashes %}
        {% if flashes is not empty %}
            <div class="pointer-events-none fixed bottom-4 right-4 z-50 flex w-full max-w-sm flex-col gap-2">
                {% for label, messages in flashes %}
                    {% for message in messages %}
                        <div data-controller="toast"
                             class="pointer-events-auto flex items-start gap-3 rounded-lg border px-4 py-3 text-sm shadow-lg transition duration-200 ease-out {{ label == 'success' ? 'border-green-200 bg-green-50 text-green-800' : 'border-red-200 bg-red-50 text-red-800' }}">
                            <svg class="mt-0.5 h-5 w-5 flex-none" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                {% if label == 'success' %}
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                                {% else %}
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v4.5a.75.75 0 001.5 0v-4.5zM10 15a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                                {% endif %}
                            </svg>
                            <span class="flex-1">{{ message }}</span>
                            <button type="button" data-action="toast#dismiss" class="-mr-1 -mt-0.5 rounded p-0.5 text-current opacity-60 hover:opacity-100" aria-label="Dismiss">
                                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/></svg>
                            </button>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        {% endif %}

        <footer class="border-t border-gray-200 py-6 text-xs text-gray-400">
            <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-2 px-4 sm:flex-row">
                <p>{{ 'layout.footer_tagline'|trans }}</p>
                <div class="flex items-center gap-2 font-medium">
                    <a href="{{ path('change_locale', {'_locale': 'fr'}) }}" class="{{ app.request.locale == 'fr' ? 'text-indigo-600' : 'hover:text-gray-600' }}">FR</a>
                    <span aria-hidden="true">·</span>
                    <a href="{{ path('change_locale', {'_locale': 'nl'}) }}" class="{{ app.request.locale == 'nl' ? 'text-indigo-600' : 'hover:text-gray-600' }}">NL</a>
                    <span aria-hidden="true">·</span>
                    <a href="{{ path('change_locale', {'_locale': 'en'}) }}" class="{{ app.request.locale == 'en' ? 'text-indigo-600' : 'hover:text-gray-600' }}">EN</a>
                </div>
            </div>
        </footer>
    </body>
</html>
