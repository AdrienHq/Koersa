{% extends 'base.html.twig' %}

{% block title %}{{ 'error.not_found_page_title'|trans }}{% endblock %}

{% block body %}
    <div class="mx-auto max-w-md py-16 text-center">
        <p class="text-sm font-semibold text-indigo-600">{{ 'error.not_found_kicker'|trans }}</p>
        <h1 class="mt-2 text-2xl font-semibold text-gray-900">{{ 'error.not_found_title'|trans }}</h1>
        <p class="mt-2 text-sm text-gray-500">{{ 'error.not_found_intro'|trans }}</p>
        <a href="{{ path('home') }}" class="mt-6 inline-block rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">{{ 'error.not_found_cta'|trans }}</a>
    </div>
{% endblock %}
