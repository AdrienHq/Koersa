        <p class="text-sm font-semibold text-indigo-600">404</p>
        <h1 class="mt-2 text-2xl font-semibold text-gray-900">Page not found</h1>
        <p class="mt-2 text-sm text-gray-500">The page you are looking for does not exist or has moved.</p>
        <a href="{{ path('home') }}" class="mt-6 inline-block rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">Back to Koersa</a>
    </div>
{% endblock %}
