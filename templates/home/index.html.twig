{% extends 'base.html.twig' %}

{% block title %}Koersa{% endblock %}

{% block body %}
    <div class="mx-auto max-w-2xl py-16 text-center">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900">Koersa</h1>
        <p class="mt-4 text-lg text-gray-600">Crypto portfolio tracker with Belgian tax reporting.</p>
        <p class="mt-2 text-sm text-gray-500">Iteration 1 — foundation. Authentication and the portfolio dashboard are on the way.</p>

        {% if not app.user %}
            <div class="mt-8 flex justify-center gap-3">
                <a href="{{ path('register') }}" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">Get started</a>
                <a href="{{ path('login') }}" class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Sign in</a>
            </div>
        {% endif %}
    </div>
{% endblock %}
