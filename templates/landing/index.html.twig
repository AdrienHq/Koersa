{% extends 'base.html.twig' %}

{% block title %}Koersa{% endblock %}

{% block body %}
    <div class="space-y-16">
        <section class="mx-auto max-w-3xl text-center">
            <div class="mb-6 flex justify-center gap-3 text-xs font-medium text-gray-400">
                <a href="{{ path('landing', {'_locale': 'fr'}) }}" class="{{ app.request.locale == 'fr' ? 'text-indigo-600' : 'hover:text-gray-600' }}">FR</a>
                <span>·</span>
                <a href="{{ path('landing', {'_locale': 'nl'}) }}" class="{{ app.request.locale == 'nl' ? 'text-indigo-600' : 'hover:text-gray-600' }}">NL</a>
            </div>
            <h1 class="text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl">{{ 'landing.headline'|trans }}</h1>
            <p class="mt-4 text-lg text-gray-500">{{ 'landing.subheadline'|trans }}</p>
        </section>

        <section class="mx-auto max-w-2xl">
            <h2 class="text-center text-sm font-semibold uppercase tracking-wide text-gray-400">{{ 'landing.features_title'|trans }}</h2>
            <ul class="mt-6 space-y-3">
                {% for key in ['landing.bullet_import', 'landing.bullet_report', 'landing.bullet_profiles'] %}
                    <li class="flex items-start gap-3 rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-700">
                        <span class="mt-0.5 text-indigo-600">✓</span>
                        <span>{{ key|trans }}</span>
                    </li>
                {% endfor %}
            </ul>
        </section>

        <section class="mx-auto max-w-md">
            <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
                <h2 class="text-lg font-semibold text-gray-900">{{ 'landing.signup_title'|trans }}</h2>
                {{ form_start(signupForm, {'attr': {'data-turbo': 'false', 'class': 'mt-4 space-y-3'}}) }}
                    {{ form_row(signupForm.email, {'attr': {'placeholder': 'landing.email_placeholder'|trans}}) }}
                    <button type="submit" class="w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">{{ 'landing.cta'|trans }}</button>
                {{ form_end(signupForm) }}
            </div>
            <p class="mt-6 text-center text-sm italic text-gray-500">{{ 'landing.founder_note'|trans }}</p>
        </section>
    </div>
{% endblock %}
