{% extends 'base.html.twig' %}

{% block title %}{{ 'landing.meta_title'|trans }}{% endblock %}

{% block metadata %}
    <meta name="description" content="{{ 'landing.meta_description'|trans }}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Koersa">
    <meta property="og:title" content="{{ 'landing.headline'|trans }}">
    <meta property="og:description" content="{{ 'landing.subheadline'|trans }}">
    <meta property="og:locale" content="{{ app.request.locale == 'nl' ? 'nl_BE' : 'fr_BE' }}">
    <link rel="alternate" hreflang="fr" href="{{ url('landing', {'_locale': 'fr'}) }}">
    <link rel="alternate" hreflang="nl" href="{{ url('landing', {'_locale': 'nl'}) }}">
    <link rel="alternate" hreflang="x-default" href="{{ url('landing', {'_locale': 'fr'}) }}">
{% endblock %}

{% block main %}
    <main class="flex-1">
        {% block flashes %}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mx-auto mt-4 max-w-xl rounded-md border px-4 py-3 text-center text-sm {{ label == 'success' ? 'border-green-200 bg-green-50 text-green-800' : 'border-red-200 bg-red-50 text-red-800' }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        {% endblock %}

        {# Hero #}
        <section class="bg-gradient-to-b from-indigo-50 via-white to-gray-50">
            <div class="mx-auto max-w-3xl px-4 py-20 text-center sm:py-28">
                <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">{{ 'landing.headline'|trans }}</h1>
                <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-gray-600">{{ 'landing.subheadline'|trans }}</p>

                {{ form_start(signupForm, {'attr': {'data-turbo': 'false', 'class': 'mx-auto mt-10 flex max-w-md flex-col gap-3 sm:flex-row sm:items-start'}}) }}
                    <div class="flex-1 text-left">
                        {{ form_widget(signupForm.email, {'attr': {'placeholder': 'landing.email_placeholder'|trans}}) }}
                        {{ form_errors(signupForm.email) }}
                    </div>
                    <button type="submit" class="shrink-0 rounded-md bg-indigo-600 px-6 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500">{{ 'landing.cta'|trans }}</button>
                {{ form_end(signupForm) }}

                <p class="mt-3 text-xs text-gray-400">{{ 'landing.reassurance'|trans }}</p>
            </div>
        </section>

        {# Features #}
        <section class="border-t border-gray-100 bg-white py-20">
            <div class="mx-auto max-w-5xl px-4">
                <h2 class="text-center text-sm font-semibold uppercase tracking-wide text-indigo-600">{{ 'landing.features_title'|trans }}</h2>
                <div class="mt-10 grid gap-6 sm:grid-cols-3">
                    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                        <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
                        </span>
                        <p class="mt-4 text-sm leading-relaxed text-gray-700">{{ 'landing.bullet_import'|trans }}</p>
                    </div>
                    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                        <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
                        </span>
                        <p class="mt-4 text-sm leading-relaxed text-gray-700">{{ 'landing.bullet_report'|trans }}</p>
                    </div>
                    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                        <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.286z" /></svg>
                        </span>
                        <p class="mt-4 text-sm leading-relaxed text-gray-700">{{ 'landing.bullet_profiles'|trans }}</p>
                    </div>
                </div>
            </div>
        </section>

        {# Founder note #}
        <section class="bg-gray-50 py-16">
            <blockquote class="mx-auto max-w-2xl px-4 text-center text-lg italic leading-relaxed text-gray-600">
                {{ 'landing.founder_note'|trans }}
            </blockquote>
        </section>
    </main>
{% endblock %}
