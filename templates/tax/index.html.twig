{% extends 'base.html.twig' %}
{% import '_macros/info_tooltip.html.twig' as ui %}

{% block title %}{{ 'tax.page_title'|trans }}{% endblock %}

{% block body %}
    <div class="space-y-8">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-gray-900">{{ 'tax.title'|trans }}</h1>
                <p class="mt-1 text-sm text-gray-500">{{ 'tax.subtitle'|trans }}</p>
            </div>
            {% if realizedGains is not null and realizedGains.perAsset|length > 0 %}
                <a href="{{ path('tax_report_pdf') }}" class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-500">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16"/></svg>
                    {{ 'tax.download_pdf'|trans }}
                </a>
            {% endif %}
        </div>

        {% if realizedGains is null or realizedGains.perAsset|length == 0 %}
            <div class="rounded-xl border border-dashed border-gray-300 bg-white px-6 py-16 text-center">
                <h2 class="text-lg font-semibold text-gray-900">{{ 'tax.empty_title'|trans }}</h2>
                <p class="mt-2 text-sm text-gray-500">{{ 'tax.empty_body'|trans }}</p>
            </div>
        {% else %}
            {# Realized-gains hero stats #}
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="rounded-xl border border-gray-200 bg-white px-6 py-5 shadow-sm">
                    <p class="flex items-center text-xs font-medium uppercase tracking-wide text-gray-500">
                        <span>{{ 'portfolio.realized_gains_hero_gain'|trans({'%year%': realizedGainsYear}) }}</span>
                        {{ ui.info_tooltip('portfolio.realized_gains_hero_gain_tooltip'|trans) }}
                    </p>
                    <p class="mt-2 text-3xl font-semibold tabular-nums {{ realizedGains.totalGainEur.isNegative ? 'text-rose-600' : 'text-emerald-600' }}">
                        €{{ realizedGains.totalGainEur.amount|number_format(2, '.', '') }}
                    </p>
                </div>
                <div class="rounded-xl border border-gray-200 bg-white px-6 py-5 shadow-sm">
                    <p class="flex items-center text-xs font-medium uppercase tracking-wide text-gray-500">
                        <span>{{ 'portfolio.realized_gains_hero_cost'|trans({'%year%': realizedGainsYear}) }}</span>
                        {{ ui.info_tooltip('portfolio.realized_gains_hero_cost_tooltip'|trans) }}
                    </p>
                    <p class="mt-2 text-3xl font-semibold tabular-nums text-gray-900">
                        €{{ realizedGains.totalCostBasisEur.amount|number_format(2, '.', '') }}
                    </p>
                </div>
            </div>

            {# Potential tax owed — three Belgian regimes #}
            {% if taxEstimates is not null %}
                <section>
                    <h2 class="flex items-center text-xs font-semibold uppercase tracking-wide text-gray-500">
                        <span>{{ 'portfolio.tax_estimates_title'|trans({'%year%': realizedGainsYear}) }}</span>
                        {{ ui.info_tooltip('portfolio.tax_estimates_tooltip'|trans) }}
                    </h2>

                    <div class="mt-3 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                        <table class="min-w-full divide-y divide-gray-200 text-sm">
                            <thead class="bg-gray-50/80 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                                <tr>
                                    <th class="px-6 py-3">{{ 'portfolio.tax_estimates_th_regime'|trans }}</th>
                                    <th class="px-6 py-3">{{ 'portfolio.tax_estimates_th_rate'|trans }}</th>
                                    <th class="px-6 py-3 text-right">{{ 'portfolio.tax_estimates_th_amount'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                {% for estimate in taxEstimates %}
                                    <tr class="align-top">
                                        <td class="px-6 py-3">
                                            <div class="font-medium text-gray-900">{{ ('portfolio.tax_regime_' ~ estimate.regime.value)|trans }}</div>
                                            <div class="mt-0.5 text-xs text-gray-500">{{ ('portfolio.tax_regime_' ~ estimate.regime.value ~ '_who')|trans }}</div>
                                        </td>
                                        <td class="whitespace-nowrap px-6 py-3 text-gray-700 tabular-nums">{{ ('portfolio.tax_regime_' ~ estimate.regime.value ~ '_rate')|trans }}</td>
                                        <td class="px-6 py-3 text-right tabular-nums font-medium text-gray-900">
                                            {% if estimate.amountEur is null %}
                                                <span class="text-gray-500">{{ 'portfolio.tax_estimates_amount_varies'|trans }}</span>
                                            {% else %}
                                                €{{ estimate.amountEur.amount|number_format(2, '.', '') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {% if realizedGainIsLoss %}
                        <p class="mt-2 text-xs text-amber-600">{{ 'portfolio.tax_estimates_loss_note'|trans({'%year%': realizedGainsYear}) }}</p>
                    {% endif %}
                    <p class="mt-1 text-xs text-gray-400">{{ 'portfolio.tax_estimates_disclaimer'|trans }}</p>
                </section>
            {% endif %}

            {# How to declare (ADR 0008) — per regime, the Belgian Cadre/code mapping #}
            {% if filingGuidances is not null %}
                <section>
                    <h2 class="flex items-center text-xs font-semibold uppercase tracking-wide text-gray-500">
                        <span>{{ 'tax.how_to_declare_title'|trans({'%year%': realizedGainsYear}) }}</span>
                        {{ ui.info_tooltip('tax.how_to_declare_tooltip'|trans) }}
                    </h2>

                    <div class="mt-3 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                        <table class="min-w-full divide-y divide-gray-200 text-sm">
                            <thead class="bg-gray-50/80 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                                <tr>
                                    <th class="px-6 py-3">{{ 'tax.how_to_declare_th_regime'|trans }}</th>
                                    <th class="px-6 py-3">{{ 'tax.how_to_declare_th_where'|trans }}</th>
                                    <th class="px-6 py-3 text-right">{{ 'tax.how_to_declare_th_amount'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                {% for guidance in filingGuidances %}
                                    <tr class="align-top">
                                        <td class="px-6 py-3">
                                            <div class="font-medium text-gray-900">{{ ('portfolio.tax_regime_' ~ guidance.regime.value)|trans }}</div>
                                            <div class="mt-0.5 text-xs text-gray-500">{{ guidance.noteKey|trans }}</div>
                                        </td>
                                        <td class="px-6 py-3 text-gray-700">
                                            {% if guidance.boxLabelKey is null %}
                                                <span class="text-gray-500">{{ 'tax.how_to_declare_no_box'|trans }}</span>
                                            {% else %}
                                                <div class="font-medium text-gray-900">{{ guidance.boxLabelKey|trans }}</div>
                                                {% if guidance.codeLabelKey is not null %}
                                                    <div class="mt-0.5 text-xs text-gray-500 tabular-nums">{{ guidance.codeLabelKey|trans }}</div>
                                                {% endif %}
                                            {% endif %}
                                        </td>
                                        <td class="px-6 py-3 text-right tabular-nums font-medium text-gray-900">
                                            {% if guidance.amount is null %}
                                                <span class="text-gray-500">{{ 'tax.how_to_declare_no_amount'|trans }}</span>
                                            {% else %}
                                                €{{ guidance.amount.amount|number_format(2, '.', '') }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    <p class="mt-2 text-xs text-gray-400">{{ 'tax.how_to_declare_disclaimer'|trans }}</p>
                </section>
            {% endif %}

            {# Realized gains by asset #}
            <section>
                <h2 class="text-xs font-semibold uppercase tracking-wide text-gray-500">{{ 'portfolio.realized_gains_title'|trans({'%year%': realizedGainsYear}) }}</h2>
                <div class="mt-3 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50/80 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                            <tr>
                                <th class="px-6 py-3">{{ 'portfolio.realized_gains_th_asset'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.realized_gains_th_proceeds'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.realized_gains_th_cost'|trans }}</th>
                                <th class="px-6 py-3 text-right">{{ 'portfolio.realized_gains_th_gain'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            {% for line in realizedGains.perAsset %}
                                <tr class="transition hover:bg-gray-50">
                                    <td class="px-6 py-3 font-medium text-gray-900">{{ line.asset }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums text-gray-700">€{{ line.proceedsEur.amount|number_format(2, '.', '') }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums text-gray-700">€{{ line.costBasisEur.amount|number_format(2, '.', '') }}</td>
                                    <td class="px-6 py-3 text-right tabular-nums font-medium {{ line.gainEur.isNegative ? 'text-rose-600' : 'text-emerald-600' }}">€{{ line.gainEur.amount|number_format(2, '.', '') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <p class="mt-2 text-xs text-gray-400">{{ 'portfolio.realized_gains_method_note'|trans }}</p>
                {% if realizedGains.unmatchedSellCount > 0 %}
                    <p class="mt-1 text-xs text-amber-600">{{ 'portfolio.realized_gains_unmatched_note'|trans({'%count%': realizedGains.unmatchedSellCount}) }}</p>
                {% endif %}
            </section>
        {% endif %}
    </div>
{% endblock %}
