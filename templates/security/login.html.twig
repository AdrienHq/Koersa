{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.login_page_title'|trans }}{% endblock %}

{% block body %}
    <div class="mx-auto max-w-md">
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
            <h1 class="text-2xl font-semibold text-gray-900">{{ 'auth.login_title'|trans }}</h1>

            {% if error %}
                {# Generic message regardless of which exception fired (no
                   user-enumeration via differing errors). #}
                <div class="mt-4 flex items-start gap-3 rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm font-medium text-red-800" role="alert">
                    <svg class="mt-0.5 h-5 w-5 flex-none" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v4.5a.75.75 0 001.5 0v-4.5zM10 15a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                    </svg>
                    <span>{{ 'auth.login_invalid_credentials'|trans }}</span>
                </div>
            {% endif %}

            <form method="post" action="{{ path('login') }}" data-turbo="false" class="mt-6 space-y-4">
                <div>
                    <label for="username" class="mb-1 block text-sm font-medium text-gray-700">{{ 'auth.login_email_label'|trans }}</label>
                    <input type="email" id="username" name="_username" value="{{ last_username }}" required autofocus
                           class="block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                </div>
                <div>
                    <label for="password" class="mb-1 block text-sm font-medium text-gray-700">{{ 'auth.login_password_label'|trans }}</label>
                    <input type="password" id="password" name="_password" required
                           class="block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                </div>

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">{{ 'auth.login_submit'|trans }}</button>
            </form>

            <p class="mt-4 text-center text-sm text-gray-500">
                {{ 'auth.login_no_account'|trans }} <a href="{{ path('register') }}" class="font-medium text-indigo-600 hover:text-indigo-500">{{ 'auth.login_register_link'|trans }}</a>.
            </p>
        </div>
    </div>
{% endblock %}
