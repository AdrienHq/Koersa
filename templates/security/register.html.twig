{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.register_page_title'|trans }}{% endblock %}

{% block body %}
    <div class="mx-auto max-w-md">
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
            <h1 class="text-2xl font-semibold text-gray-900">{{ 'auth.register_title'|trans }}</h1>
            <p class="mt-1 text-sm text-gray-500">{{ 'auth.register_intro'|trans }}</p>

            {# Auth flows use full-page navigation; Turbo would swallow the 302 redirect. #}
            {{ form_start(registrationForm, {'attr': {'data-turbo': 'false', 'class': 'mt-6'}}) }}
                {% if registrationForm.vars.submitted and not registrationForm.vars.valid %}
                    <div class="mb-4 flex items-start gap-3 rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm font-medium text-red-800" role="alert">
                        <svg class="mt-0.5 h-5 w-5 flex-none" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v4.5a.75.75 0 001.5 0v-4.5zM10 15a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                        </svg>
                        <span>{{ 'auth.login_form_has_errors'|trans }}</span>
                    </div>
                {% endif %}
                {{ form_row(registrationForm.email) }}
                {{ form_row(registrationForm.organizationName) }}
                {{ form_row(registrationForm.plainPassword.first) }}
                {{ form_row(registrationForm.plainPassword.second) }}
                <button type="submit" class="mt-2 w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">{{ 'auth.register_submit'|trans }}</button>
            {{ form_end(registrationForm) }}

            <p class="mt-4 text-center text-sm text-gray-500">
                {{ 'auth.register_already_have_account'|trans }} <a href="{{ path('login') }}" class="font-medium text-indigo-600 hover:text-indigo-500">{{ 'auth.register_sign_in_link'|trans }}</a>.
            </p>
        </div>
    </div>
{% endblock %}
