{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.page_title'|trans }}{% endblock %}

{% block body %}
    <div class="space-y-8">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-gray-900">{{ 'admin.title'|trans }}</h1>
            <p class="mt-1 text-sm text-gray-500">{{ 'admin.subtitle'|trans }}</p>
        </div>

        {# Counts #}
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
            <div class="rounded-xl border border-gray-200 bg-white px-6 py-5 shadow-sm">
                <p class="text-xs font-medium uppercase tracking-wide text-gray-500">{{ 'admin.stat_signups'|trans }}</p>
                <p class="mt-2 text-3xl font-semibold tabular-nums text-gray-900">{{ signupCount }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white px-6 py-5 shadow-sm">
                <p class="text-xs font-medium uppercase tracking-wide text-gray-500">{{ 'admin.stat_users'|trans }}</p>
                <p class="mt-2 text-3xl font-semibold tabular-nums text-gray-900">{{ userCount }}</p>
            </div>
            <div class="rounded-xl border border-gray-200 bg-white px-6 py-5 shadow-sm">
                <p class="text-xs font-medium uppercase tracking-wide text-gray-500">{{ 'admin.stat_organizations'|trans }}</p>
                <p class="mt-2 text-3xl font-semibold tabular-nums text-gray-900">{{ organizationCount }}</p>
            </div>
        </div>

        {# Recent signups #}
        <section>
            <h2 class="text-xs font-semibold uppercase tracking-wide text-gray-500">{{ 'admin.signups_title'|trans }}</h2>
            {% if recentSignups is empty %}
                <div class="mt-3 rounded-xl border border-dashed border-gray-300 bg-white px-6 py-12 text-center">
                    <p class="text-sm text-gray-500">{{ 'admin.signups_empty'|trans }}</p>
                </div>
            {% else %}
                <div class="mt-3 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50/80 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                            <tr>
                                <th class="px-6 py-3">{{ 'admin.col_email'|trans }}</th>
                                <th class="px-6 py-3">{{ 'admin.col_locale'|trans }}</th>
                                <th class="px-6 py-3">{{ 'admin.col_signed_up_at'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            {% for signup in recentSignups %}
                                <tr>
                                    <td class="px-6 py-3 font-medium text-gray-900">{{ signup.email }}</td>
                                    <td class="px-6 py-3 text-gray-700 uppercase">{{ signup.locale }}</td>
                                    <td class="whitespace-nowrap px-6 py-3 text-gray-500">{{ signup.signedUpAt|date('Y-m-d H:i') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </section>

        {# Recent users #}
        <section>
            <h2 class="text-xs font-semibold uppercase tracking-wide text-gray-500">{{ 'admin.users_title'|trans }}</h2>
            {% if recentUsers is empty %}
                <div class="mt-3 rounded-xl border border-dashed border-gray-300 bg-white px-6 py-12 text-center">
                    <p class="text-sm text-gray-500">{{ 'admin.users_empty'|trans }}</p>
                </div>
            {% else %}
                <div class="mt-3 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50/80 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                            <tr>
                                <th class="px-6 py-3">{{ 'admin.col_email'|trans }}</th>
                                <th class="px-6 py-3">{{ 'admin.col_admin'|trans }}</th>
                                <th class="px-6 py-3">{{ 'admin.col_registered_at'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            {% for user in recentUsers %}
                                <tr>
                                    <td class="px-6 py-3 font-medium text-gray-900">{{ user.email }}</td>
                                    <td class="px-6 py-3">
                                        {% if user.isAdmin %}
                                            <span class="inline-flex rounded-full bg-indigo-50 px-2 py-0.5 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-200">{{ 'admin.badge_admin'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="whitespace-nowrap px-6 py-3 text-gray-500">{{ user.registeredAt|date('Y-m-d H:i') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </section>

        {# Recent orgs #}
        <section>
            <h2 class="text-xs font-semibold uppercase tracking-wide text-gray-500">{{ 'admin.organizations_title'|trans }}</h2>
            {% if recentOrganizations is empty %}
                <div class="mt-3 rounded-xl border border-dashed border-gray-300 bg-white px-6 py-12 text-center">
                    <p class="text-sm text-gray-500">{{ 'admin.organizations_empty'|trans }}</p>
                </div>
            {% else %}
                <div class="mt-3 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50/80 text-left text-xs font-medium uppercase tracking-wide text-gray-500">
                            <tr>
                                <th class="px-6 py-3">{{ 'admin.col_name'|trans }}</th>
                                <th class="px-6 py-3">{{ 'admin.col_slug'|trans }}</th>
                                <th class="px-6 py-3">{{ 'admin.col_created_at'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            {% for org in recentOrganizations %}
                                <tr>
                                    <td class="px-6 py-3 font-medium text-gray-900">{{ org.name }}</td>
                                    <td class="px-6 py-3 text-gray-500 font-mono">{{ org.slug }}</td>
                                    <td class="whitespace-nowrap px-6 py-3 text-gray-500">{{ org.createdAt|date('Y-m-d H:i') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </section>
    </div>
{% endblock %}
